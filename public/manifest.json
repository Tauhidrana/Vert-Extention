{
  "manifest_version": 3,
  "name": "ZverTs Focus",
  "short_name": "ZverTs Focus",
  "version": "1.0.0",
  "description": "AI-powered distraction blocker and learning protection for ZverTs students.",
  "action": {
    "default_title": "ZverTs Focus",
    "default_popup": "src/popup/index.html"
  },
  "options_page": "src/options/index.html",
  "background": {
    "service_worker": "assets/background.js",
    "type": "module"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": [
    "alarms",
    "declarativeNetRequest",
    "identity",
    "notifications",
    "scripting",
    "storage",
    "tabs",
    "webNavigation"
  ],
  "host_permissions": [
    "https://www.zverts.com/*",
    "https://*.zverts.com/*",
    "https://*.supabase.co/*",
    "https://*.youtube.com/*",
    "https://youtube.com/*",
    "https://facebook.com/*",
    "https://*.facebook.com/*",
    "https://instagram.com/*",
    "https://*.instagram.com/*",
    "https://messenger.com/*",
    "https://*.messenger.com/*",
    "https://threads.net/*",
    "https://*.threads.net/*",
    "https://x.com/*",
    "https://*.x.com/*",
    "https://twitter.com/*",
    "https://*.twitter.com/*",
    "https://reddit.com/*",
    "https://*.reddit.com/*",
    "https://discord.com/*",
    "https://*.discord.com/*",
    "https://linkedin.com/*",
    "https://*.linkedin.com/*",
    "https://tiktok.com/*",
    "https://*.tiktok.com/*",
    "https://web.whatsapp.com/*",
    "https://netflix.com/*",
    "https://*.netflix.com/*",
    "https://primevideo.com/*",
    "https://*.primevideo.com/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.zverts.com/*", "https://*.zverts.com/*"],
      "js": ["assets/zvertsContent.js"],
      "run_at": "document_start"
    },
    {
      "matches": ["https://www.youtube.com/*", "https://youtube.com/*"],
      "js": ["assets/youtubeLearning.js"],
      "run_at": "document_start"
    }
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "static_ads",
        "enabled": true,
        "path": "rules/static-ads.json"
      }
    ]
  },
  "web_accessible_resources": [
    {
      "resources": ["assets/*", "icons/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
